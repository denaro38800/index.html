<script>
// ===== barre de progression =====
const bar=document.getElementById('progress');
addEventListener('scroll',()=>{
  const h=document.documentElement;
  bar.style.width=(h.scrollTop/(h.scrollHeight-h.clientHeight)*100)+'%';
},{passive:true});

// ===== reveal au scroll =====
const io=new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}});
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

// ===== compteurs animés =====
const reduce=matchMedia('(prefers-reduced-motion: reduce)').matches;
const cio=new IntersectionObserver(es=>{
  es.forEach(e=>{
    if(!e.isIntersecting)return;
    const el=e.target,end=+el.dataset.count;cio.unobserve(el);
    if(reduce){el.textContent=end;return}
    const t0=performance.now(),dur=1400;
    (function tick(t){
      const p=Math.min((t-t0)/dur,1),ease=1-Math.pow(1-p,3);
      el.textContent=Math.round(end*ease);
      if(p<1)requestAnimationFrame(tick);
    })(t0);
  });
},{threshold:.5});
document.querySelectorAll('[data-count]').forEach(el=>cio.observe(el));

// ===== jauge de vol vivante =====
const SEGS=8,gauge=document.getElementById('gauge'),
      gTitle=document.getElementById('gaugeTitle'),
      gCount=document.getElementById('gaugeCount');
for(let i=0;i<SEGS;i++){const s=document.createElement('div');s.className='seg';gauge.appendChild(s)}
const segs=[...gauge.children];
let hits=0;
function setTitle(){
  if(hits>=SEGS){gTitle.textContent='💥 MASQUE PERDU';gTitle.style.color='var(--bug)'}
  else if(hits>=6){gTitle.textContent='⚠ VOL IMMINENT';gTitle.style.color='var(--bug)'}
  else if(hits>=4){gTitle.textContent='MASQUE ATTAQUÉ';gTitle.style.color='var(--gold)'}
  else{gTitle.textContent='JAUGE DE VOL';gTitle.style.color='var(--ink)'}
  gCount.textContent=hits+' / '+SEGS;
}
function colorFor(i){
  const f=i/(SEGS-1);
  return f<0.45?'var(--ember)':f<0.75?'var(--gold)':'var(--bug)';
}
if(!reduce){
  setInterval(()=>{
    if(hits<SEGS){
      segs[hits].style.setProperty('--segc',colorFor(hits));
      segs[hits].classList.add('full');
      hits++;setTitle();
    }else{
      setTimeout(()=>{segs.forEach(s=>s.classList.remove('full'));hits=0;setTitle()},150);
    }
  },720);
}else{
  segs.slice(0,5).forEach((s,i)=>{s.style.setProperty('--segc',colorFor(i));s.classList.add('full')});
  hits=5;setTitle();
}
setTitle();
</script>
